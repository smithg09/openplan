{
  "name": "openplan",
  "version": "0.3.0",
  "private": true,
  "description": "Interactive plan review for Claude Code — annotate, version, and manage plans in a browser UI.",
  "author": "Smith Gajjar <smith.gajjar@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smithg09/openplan.git"
  },
  "homepage": "https://github.com/smithg09/openplan",
  "keywords": [
    "claude-code",
    "planning",
    "review",
    "hooks",
    "annotations",
    "cli"
  ],
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:ui": "bun run --cwd apps/ui dev",
    "dev:landing": "bun run --cwd apps/landing-page dev",
    "build:ui": "bun run --cwd apps/ui build",
    "build:landing": "bun run --cwd apps/landing-page build",
    "build:cli": "cd apps/cli && go build -o ../../bin/openplan .",
    "build": "bun run build:ui && bun run build:cli",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:cli": "cd apps/cli && go test ./...",
    "test:coverage:cli": "cd apps/cli && go test ./... -coverprofile=coverage.out && go tool cover -func=coverage.out | grep total"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
